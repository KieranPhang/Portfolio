---
// src/pages/cooking.astro
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";

// Prefix paths correctly for GitHub Pages base URL
const withBase = (p: string) => `${import.meta.env.BASE_URL}${p.replace(/^\//, "")}`;

const cookingDescription =
  "A cooking log by Kieran Phang-Davey: recipes treated like engineering problems, tuned one variable at a time until the version that actually works.";

type Recipe = {
  name: string;
  slug: string;
  description: string;
};

type CuisineSection = {
  label: string;
  recipes: Recipe[];
};

const cuisines: CuisineSection[] = [
  {
    label: "Basics",
    recipes: [
      {
        name: "Soup-Pot Chicken Stock",
        slug: "soup-pot-chicken-stock",
        description:
          "I turn a stripped rotisserie chicken carcass into a clean stock with a five to six hour bare simmer instead of a pressure cooker.",
      },
    ],
  },
  {
    label: "Chinese",
    recipes: [
      {
        name: "Salt-Baked Chicken",
        slug: "salt-baked-chicken",
        description:
          "Cantonese salt-baked chicken done the practical way: a seasoning rub and a foil wrap standing in for a full clay burial, still juicy under a crowded banquet oven.",
      },
      {
        name: "Singapore Pork Chop Hor Fun",
        slug: "singapore-pork-chop-hor-fun",
        description:
          "Charred wok noodles under a silky pork and egg gravy, tuned down to the gram after the pantry ran low on soy sauce.",
      },
      {
        name: "Hong Shao Rou",
        slug: "hong-shao-rou",
        description:
          "I caramelize sugar in rendered pork fat, braise the belly low and slow in soy and Shaoxing wine, then reduce the liquid until it turns glossy.",
      },
      {
        name: "Beggar's Chicken",
        slug: "beggars-chicken",
        description:
          "I brine a whole chicken, rub it with a five-spice marinade, stuff it with shiitake and lap cheong, and seal it in lotus leaf, parchment, and foil to bake.",
      },
      {
        name: "Soy-Braised Tri-Tip",
        slug: "soy-braised-tri-tip",
        description:
          "I sear tri-tip hard, braise it low with soy and star anise, then glaze the sliced beef in the reduced liquid for under two minutes so it doesn't dry out.",
      },
      {
        name: "Mapo Tofu",
        slug: "mapo-tofu",
        description:
          "I fry ground pork with doubanjiang until the oil turns red, then simmer in soft tofu cubes just long enough for the sauce to lightly thicken.",
      },
      {
        name: "Fried Egg Tofu with Minced Pork",
        slug: "fried-egg-tofu-with-minced-pork",
        description:
          "I fry egg tofu rounds until golden, then simmer them in a soy and shiitake sauce built from minced pork and the mushroom soaking liquid.",
      },
      {
        name: "Silken Steamed Egg with Minced Pork",
        slug: "silken-steamed-egg-with-minced-pork",
        description:
          "I strain a warm-stock egg mixture into a shallow dish, steam it low until barely set, then finish it with seasoned minced pork so the texture jiggles like soft tofu.",
      },
    ],
  },
  {
    label: "Japanese",
    recipes: [
      {
        name: "Japanese Beef Curry",
        slug: "japanese-beef-curry",
        description:
          "I braise chuck roll with kombu and dashi until fork-tender, then finish it with Japanese curry roux over rice.",
      },
      {
        name: "Chicken Katsu",
        slug: "chicken-katsu",
        description:
          "I pound chicken thighs even, coat them flour-egg-panko, and shallow-fry them for a crust that survives resting on a rack.",
      },
      {
        name: "Hambāgu",
        slug: "hambagu",
        description:
          "I sear onion-and-egg-bound beef patties, then finish them in a glossy ketchup and Worcestershire sauce built in the same pan.",
      },
    ],
  },
  {
    label: "Korean",
    recipes: [
      {
        name: "Shin-Style Ramyeon",
        slug: "shin-style-ramyeon",
        description:
          "A copycat of the beefy, garlicky Shin Ramyeon broth, built from cheap noodle bricks and a hand-tuned spice mix, scaled from one bowl up to a seven-pack hot dog batch.",
      },
    ],
  },
  {
    label: "Southeast Asian",
    recipes: [
      {
        name: "Kampung-Style Steamed Ginger Chicken and Stock Rice",
        slug: "kampung-style-steamed-ginger-chicken-and-stock-rice",
        description:
          "I steam garlic-ginger marinated chicken thighs and spoon the accumulated juices over rice that I cook in chicken stock instead of water.",
      },
      {
        name: "Sambal Belacan Barracuda",
        slug: "sambal-belacan-barracuda",
        description:
          "I fry barracuda steaks, then coat them in a coarse chili, garlic, shallot, and belacan sambal fried dark red in the same pan.",
      },
      {
        name: "Spicy Coconut Barracuda Head-and-Tail Curry",
        slug: "spicy-coconut-barracuda-head-and-tail-curry",
        description:
          "I build a curry powder and coconut milk base, then stagger the barracuda head and tail into the pot on their own timers so the fish never overcooks.",
      },
      {
        name: "Coconut-Broth Meatballs",
        slug: "coconut-broth-meatballs",
        description:
          "I bind beef meatballs with soaked bread and milk, then simmer them gently in a lemongrass and coconut broth that I keep from ever boiling hard so it doesn't split.",
      },
    ],
  },
  {
    label: "Fusion",
    recipes: [
      {
        name: "Spicy Garlic-Chili Ground Beef",
        slug: "spicy-garlic-chili-ground-beef",
        description:
          "A fifteen-minute garlic and chili ground beef base built to drop into rice bowls, tacos, or flatbread without a second thought.",
      },
      {
        name: "Spicy Stir-Fry Egg Noodles",
        slug: "spicy-stir-fry-egg-noodles",
        description:
          "I stir-fry sliced pork or beef with chili paste, toss in boiled egg noodles, and top each portion with a fried egg.",
      },
    ],
  },
  {
    label: "Latin American",
    recipes: [
      {
        name: "Mexican Pork and Bean Meal Prep",
        slug: "mexican-pork-and-bean-meal-prep",
        description:
          "One slow-cooked pork and black bean base, split into crispy wraps and rice bowls for eight meals without repeating the same plate twice.",
      },
      {
        name: "Refried Black Beans",
        slug: "refried-black-beans",
        description:
          "Dried beans cooked down and mashed into a spreadable, garlicky refry, with a dedicated wok method that keeps the seasoning intact.",
      },
      {
        name: "Chicken Quesadillas",
        slug: "chicken-quesadillas",
        description:
          "I fold shredded rotisserie chicken and a heavy layer of cheese into a flour tortilla and crisp it in a skillet, no onion.",
      },
      {
        name: "El Pollo Loco-Style BBQ Chicken",
        slug: "el-pollo-loco-style-bbq-chicken",
        description:
          "I marinate chicken in orange juice, lime, garlic, and cumin overnight, then grill it slowly, watching the citrus sugars so they char instead of burn.",
      },
    ],
  },
  {
    label: "Western",
    recipes: [
      {
        name: "Brown Butter Coffee Cookies",
        slug: "brown-butter-coffee-cookies",
        description:
          "Gluten-free cookies built on browned butter and dissolved instant coffee, with a mandatory chill that's the difference between gritty and right.",
      },
      {
        name: "Costco-Style Mocha Freeze",
        slug: "costco-style-mocha-freeze",
        description:
          "A copycat mocha freeze fixed by an ice-ratio correction and a frozen coffee-cube method that skips the meltwater dilution.",
      },
      {
        name: "Popeyes-Style Air Fryer Chicken",
        slug: "popeyes-style-air-fryer-chicken",
        description:
          "Crackly, spiced drumsticks built for the air fryer, double-dredged and rested so the crust actually bonds before it hits the basket.",
      },
      {
        name: "Cajun One-Pot Chicken and Rice",
        slug: "cajun-one-pot-chicken-and-rice",
        description:
          "I brown Cajun-seasoned chicken thighs, then build the rice right in the same skillet so it picks up all the fond.",
      },
      {
        name: "Creamy Garlic Chicken Pasta",
        slug: "creamy-garlic-chicken-pasta",
        description:
          "I sear chicken thighs, build a garlic-Parmesan cream sauce in the same pan, then toss it all with pasta in about 30 minutes.",
      },
      {
        name: "Chicken Schnitzel with Red Sauce",
        slug: "chicken-schnitzel-with-red-sauce",
        description:
          "I fry Parmesan-panko chicken schnitzel and keep the sauce mostly underneath so the fried crust stays crisp on the plate.",
      },
      {
        name: "Chicken Cutlet with Mushroom Cream Gravy",
        slug: "chicken-cutlet-with-mushroom-cream-gravy",
        description:
          "I fry breaded chicken cutlets, then build a mushroom cream gravy in the same skillet and pour it over right before serving.",
      },
      {
        name: "Beef Red-Sauce Pasta",
        slug: "beef-red-sauce-pasta",
        description:
          "I brown ground beef and mushrooms, deglaze with red wine, and simmer everything into a Worcestershire-backed tomato sauce for pasta.",
      },
      {
        name: "Barracuda Steak with Fennel Purée and Citrus Beurre Blanc",
        slug: "barracuda-steak-with-fennel-puree-and-citrus-beurre-blanc",
        description:
          "I sear lean barracuda steaks and plate them over a sieved fennel and cream purée, with a lemon beurre blanc spooned around and a green herb oil finish.",
      },
      {
        name: "Barramundi with Beurre Blanc, Yukon Gold Mash, and Asparagus",
        slug: "barramundi-with-beurre-blanc-yukon-gold-mash-and-asparagus",
        description:
          "I run this whole plate, mash, asparagus, seared barramundi, and beurre blanc, off a 45-minute countdown clock so everything lands hot at once.",
      },
    ],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={cookingDescription} />
    <title>Kitchen | {siteConfig.name}</title>
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-6xl mx-auto px-6 space-y-12">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em] text-blue-500">Kitchen</p>
          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">Recipes, iterated until perfection</h1>
          <p class="text-base sm:text-lg text-gray-400 max-w-3xl">
            I treat recipes the same way I treat an engineering problem: pick one variable, run the test,
            write down what happened, and change exactly one thing next time. These are the logs from that
            process, some of them clean finished recipes, some of them still mid-iteration, all of them
            documented instead of trusted to memory.
          </p>
        </header>

        {cuisines
          .filter((section) => section.recipes.length > 0)
          .map((section) => (
            <div class="space-y-6">
              <h2 class="text-xl font-semibold uppercase tracking-[0.15em] text-gray-300 border-b border-slate-800 pb-2">
                {section.label}
              </h2>

              <div class="grid gap-6 sm:gap-8 md:grid-cols-2">
                {section.recipes.map((recipe) => (
                  <article class="flex flex-col overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60 shadow-lg shadow-black/30">
                    <div class="h-40 bg-gradient-to-br from-blue-500/40 via-purple-500/30 to-slate-900" />

                    <div class="flex flex-1 flex-col p-6 space-y-4">
                      <header class="space-y-1">
                        <h3 class="text-xl font-semibold text-gray-100">{recipe.name}</h3>
                        <p class="text-sm text-slate-400 line-clamp-3">{recipe.description}</p>
                      </header>

                      <div class="pt-2 mt-auto">
                        <a
                          href={withBase(`cooking/${recipe.slug}`)}
                          class="inline-flex items-center rounded-full bg-blue-600 px-5 py-2 text-sm font-medium text-white hover:bg-blue-500 transition"
                        >
                          View recipe →
                        </a>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))}
      </section>
    </main>

    <Footer />
  </body>
</html>
