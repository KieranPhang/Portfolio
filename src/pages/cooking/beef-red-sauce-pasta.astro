---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Beef Red-Sauce Pasta";
const recipeTagline = "Ground beef and mushrooms browned down into a red wine and Worcestershire tomato sauce.";
const recipeDescription =
  "I brown ground beef and mushrooms, deglaze with red wine, and simmer everything into a Worcestershire-backed tomato sauce for pasta.";

const ingredients = [
  "1½-2 pounds ground beef",
  "1 onion, diced",
  "4 garlic cloves, minced",
  "12-16 ounces mushrooms, sliced",
  "2 tablespoons tomato paste",
  "½ cup red wine",
  "1-2 cans crushed tomatoes or passata",
  "1 tablespoon Worcestershire sauce",
  "12-16 ounces pasta",
  "Olive oil",
  "Salt and black pepper",
];

const steps = [
  "Heat a large pot or deep skillet over medium-high heat.",
  "Brown the beef thoroughly. Remove it and leave only enough fat to cook the vegetables.",
  "Add the onion and mushrooms. Cook for 6-8 minutes.",
  "Add the garlic and cook for 30 seconds.",
  "Add the tomato paste and cook for 1-2 minutes.",
  "Deglaze with the red wine and reduce for 1-2 minutes.",
  "Add the crushed tomatoes, Worcestershire sauce, and browned beef.",
  "Reduce the heat and simmer for about 45 minutes.",
  "Cook the pasta until al dente.",
  "Toss the pasta with enough sauce to coat it. Adjust seasoning before serving.",
];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "American",
  recipeYield: "About 4 portions",
  recipeIngredient: ingredients,
  recipeInstructions: steps.map((step) => ({
    "@type": "HowToStep",
    text: step,
  })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Western
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Ingredients</h2>
          <p class="text-sm text-gray-500">About 4 portions.</p>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {ingredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {steps.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
