---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Barramundi with Beurre Blanc, Yukon Gold Mash, and Asparagus";
const recipeTagline = "A four-plate service built off a 45-minute countdown clock, skin-crisped barramundi over mash with beurre blanc.";
const recipeDescription =
  "I run this whole plate, mash, asparagus, seared barramundi, and beurre blanc, off a 45-minute countdown clock so everything lands hot at once.";

const fishIngredients = [
  "4 skin-on barramundi fillets, 6-8 ounces each",
  "Salt and black pepper",
  "Neutral oil",
  "Butter for basting",
];

const mashIngredients = [
  "3 pounds Yukon Gold potatoes",
  "8 tablespoons butter",
  "⅔ cup heavy cream, warmed",
  "1½ teaspoons kosher salt, then adjust to taste",
];

const asparagusIngredients = ["2 bunches thin asparagus, trimmed", "2 tablespoons butter", "Salt"];

const beurreBlancIngredients = [
  "12 ounces cold butter, cut into cubes",
  "2 shallots, finely minced",
  "⅔ cup dry Sauvignon Blanc or Pinot Grigio",
  "¼ cup heavy cream",
  "Juice of 1 lemon",
  "2 teaspoons Dijon mustard, optional",
  "Salt",
];

const garnishIngredients = ["2 tablespoons chopped chives", "Zest of 1 lemon"];

const allIngredients = [
  ...fishIngredients,
  ...mashIngredients,
  ...asparagusIngredients,
  ...beurreBlancIngredients,
  ...garnishIngredients,
];

const timeline = [
  {
    label: "T-45",
    steps: [
      "Preheat the oven to 170 F for holding.",
      "Put a large pot of salted water on high heat.",
      "Cut the butter for the beurre blanc into cubes and refrigerate it.",
      "Peel or scrub the potatoes and cut them into even chunks.",
    ],
  },
  {
    label: "T-39",
    steps: ["Put the potatoes into the boiling water.", "Cook until completely tender."],
  },
  {
    label: "T-26",
    steps: [
      "Bring a second pot of salted water to a boil.",
      "Blanch the asparagus for about 2 minutes.",
      "Drain and cool it quickly so it remains green.",
      "Reserve for the final sauté.",
    ],
  },
  {
    label: "T-24",
    steps: [
      "Drain the potatoes thoroughly.",
      "Return them to the hot pot briefly so surface moisture evaporates.",
      "Mash or rice them.",
      "Fold in 8 tablespoons butter.",
      "Add the warm cream gradually.",
      "Season with about 1½ teaspoons salt.",
      "Cover and hold over the lowest possible heat.",
    ],
  },
  {
    label: "T-20",
    steps: [
      "Put the shallots and white wine into a small saucepan.",
      "Simmer until the wine is reduced to only a few tablespoons.",
    ],
  },
  {
    label: "T-17",
    steps: ["Add the ¼ cup cream to the reduction.", "Simmer briefly.", "Reduce the heat to very low."],
  },
  {
    label: "T-14",
    steps: [
      "Pat the barramundi completely dry.",
      "Season both sides.",
      "Heat a large skillet over medium-high heat with a thin film of oil.",
    ],
  },
  {
    label: "T-12",
    steps: [
      "Put the fish into the pan skin-side down.",
      "Press lightly for the first 20-30 seconds to prevent curling.",
      "Cook skin-side down for approximately 5-6 minutes.",
      "Most of the cooking occurs on the skin side.",
    ],
  },
  {
    label: "T-6",
    steps: [
      "Turn the fish.",
      "Add butter and baste for 1-2 minutes.",
      "Remove at approximately 125-130 F in the center.",
      "Hold briefly in the 170 F oven only when necessary.",
    ],
  },
  {
    label: "T-5",
    steps: [
      "Remove the beurre-blanc pan from direct heat.",
      "Whisk in the cold butter one cube at a time.",
      "Add the lemon juice.",
      "Whisk in optional Dijon.",
      "Season with salt.",
      "Keep warm but never allow it to boil.",
    ],
  },
  {
    label: "T-3",
    steps: [
      "Heat 2 tablespoons butter in the second skillet.",
      "Add the blanched asparagus.",
      "Toss until hot and glossy.",
      "Season with salt.",
    ],
  },
  {
    label: "T-1: Plate",
    steps: [
      "Spoon or shape the Yukon Gold mash onto each warm plate.",
      "Place the barramundi against or partly over the mash, crispy skin facing upward.",
      "Arrange the asparagus to one side rather than burying the fish.",
      "Spoon beurre blanc around the fish while keeping the skin dry.",
      "Finish with chives and lemon zest.",
    ],
  },
];

const allSteps = timeline.flatMap((block) => block.steps.map((step) => `${block.label}: ${step}`));

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "Western",
  recipeYield: "4 portions",
  totalTime: "PT45M",
  recipeIngredient: allIngredients,
  recipeInstructions: allSteps.map((step) => ({
    "@type": "HowToStep",
    text: step,
  })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Western
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>

          <p class="text-sm sm:text-base text-gray-500">
            4 portions. Target service time is 45 minutes, with a 170 F oven held ready for holding.
          </p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Barramundi</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {fishIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Yukon Gold Mash</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {mashIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Asparagus</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {asparagusIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Beurre Blanc</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {beurreBlancIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Garnish</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {garnishIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Method and Timeline</h2>
          <p class="text-sm text-gray-500">
            Every block is timed against service, working backward from T-45 to the final plate.
          </p>
          {timeline.map((block) => (
            <div class="space-y-2">
              <h3 class="text-lg font-semibold text-gray-100">{block.label}</h3>
              <ol class="list-decimal list-inside space-y-2 text-gray-300">
                {block.steps.map((step) => <li>{step}</li>)}
              </ol>
            </div>
          ))}
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Key Control Points</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            <li>Dry skin and a properly heated pan are required for crisp barramundi skin.</li>
            <li>Do not pour sauce over the skin.</li>
            <li>Mount the beurre blanc only near service.</li>
            <li>Never boil the finished beurre blanc.</li>
            <li>The cream in this version makes the emulsion more stable for a single cook managing several components.</li>
          </ul>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
