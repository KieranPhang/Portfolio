---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Spicy Stir-Fry Egg Noodles";
const recipeTagline = "Wok-fried egg noodles with chili paste, sliced meat, and a fried egg on top.";
const recipeDescription =
  "I stir-fry sliced pork or beef with chili paste, toss in boiled egg noodles, and top each portion with a fried egg.";

const ingredients = [
  "1½-2 pounds sliced pork or beef",
  "1 pound egg noodles",
  "4 eggs",
  "4 garlic cloves, minced",
  "2-3 tablespoons chili paste or chili oil",
  "Olive oil",
  "Salt",
  "Soy sauce, optional",
  "Sliced green onion, for finishing",
];

const steps = [
  "Boil the egg noodles until just tender. Drain well.",
  "Heat a wok or large skillet until very hot.",
  "Add olive oil and stir-fry the meat quickly in batches.",
  "Add the garlic and cook for 30 seconds.",
  "Add the chili paste or chili oil and toss.",
  "Add the drained noodles.",
  "Season with salt and optional soy sauce.",
  "Fry the eggs separately.",
  "Divide the noodles into portions and top each with an egg and green onion.",
];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "Fusion",
  recipeYield: "About 4 portions",
  totalTime: "PT25M",
  recipeIngredient: ingredients,
  recipeInstructions: steps.map((step) => ({
    "@type": "HowToStep",
    text: step,
  })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Fusion
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Ingredients</h2>
          <p class="text-sm text-gray-500">About 4 portions. Total time is about 20-25 minutes.</p>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {ingredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {steps.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
