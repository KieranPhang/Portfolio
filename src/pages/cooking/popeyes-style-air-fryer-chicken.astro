---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Popeyes-Style Air Fryer Chicken";
const recipeTagline = "Crackly, spiced drumsticks double-dredged and rested so the crust bonds before it hits the air fryer basket.";
const recipeDescription =
  "Crackly, spiced drumsticks built for the air fryer, double-dredged and rested so the crust actually bonds before it hits the basket.";

const chickenIngredients = [
  "16 drumsticks",
  "1.5 tbsp salt",
  "3 eggs",
  "5 tbsp water",
  "1.5 tsp hot sauce, optional",
];

const flourIngredients = [
  "2.75 cups flour",
  "1.5 tbsp paprika",
  "1 tbsp garlic powder",
  "1 tbsp onion powder",
  "1.5 tsp cayenne",
  "1.5 tsp black pepper",
  "1.5 tsp white pepper, optional",
  "1.5 tsp salt",
  "3/4 tsp thyme",
  "3/4 tsp oregano",
  "1.5 tsp baking powder",
];

const steps = [
  "Pat drumsticks dry and salt lightly.",
  "Coat in flour.",
  "Dip in egg wash.",
  "Return to flour and press firmly to create a rough crust.",
  "Rest on a rack for 10-15 minutes so the flour hydrates and bonds.",
  "Apply a light oil mist.",
  "Air fry at 380 F for 13 minutes.",
  "Flip, spray again, and cook another 10-12 minutes.",
  "Optionally finish at 400 F for two minutes.",
  "Target an internal temperature of 175 F for drumstick texture.",
];

const mashedPotatoIngredients = [
  "2 lb potatoes",
  "4 tbsp butter",
  "1/2-3/4 cup warm milk",
  "1/2 tsp each garlic and onion powder",
  "Salt",
];

const gravyIngredients = [
  "3 tbsp butter",
  "3 tbsp flour",
  "2 cups chicken stock",
  "1/2 tsp each garlic powder, onion powder, and black pepper",
  "1 tsp soy sauce",
];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "Western",
  recipeYield: "16 drumsticks",
  recipeIngredient: [...chickenIngredients, ...flourIngredients],
  recipeInstructions: steps.map((step) => ({ "@type": "HowToStep", text: step })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Western
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>

          <p class="text-sm sm:text-base text-gray-400">Final scale: 16 drumsticks.</p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Chicken and binder</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {chickenIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Seasoned flour</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {flourIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {steps.map((step) => <li>{step}</li>)}
          </ol>
          <p class="text-gray-300 leading-relaxed">
            Cook in 2-3 uncrowded batches and hold completed pieces in a 200 F oven.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Freezing decision</h2>
          <p class="text-gray-300 leading-relaxed">
            Freezing after coating was rejected as the standard method because ice crystals can separate and
            patch the crust. A five-minute firming chill is acceptable only when unusually wet chicken
            prevents adhesion. Oil spray is required for the flour to fry rather than dry, but soaking the
            coating dissolves the crust.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Sides from the same conversation</h2>

          <h3 class="text-lg font-semibold text-gray-100">Mashed potatoes</h3>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {mashedPotatoIngredients.map((item) => <li>{item}</li>)}
          </ul>
          <p class="text-gray-300 leading-relaxed">
            Mash with butter first, add milk gradually, and whip smooth.
          </p>

          <h3 class="text-lg font-semibold text-gray-100">Gravy</h3>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {gravyIngredients.map((item) => <li>{item}</li>)}
          </ul>
          <p class="text-gray-300 leading-relaxed">
            Cook the roux three minutes, whisk in stock, simmer five minutes, and blend smooth.
          </p>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
