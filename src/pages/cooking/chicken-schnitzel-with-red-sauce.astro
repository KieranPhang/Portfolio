---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Chicken Schnitzel with Red Sauce";
const recipeTagline = "Parmesan-panko chicken schnitzel next to a simple simmered red sauce.";
const recipeDescription =
  "I fry Parmesan-panko chicken schnitzel and keep the sauce mostly underneath so the fried crust stays crisp on the plate.";

const schnitzelIngredients = [
  "About 2 pounds chicken thighs or cutlets",
  "Flour, enough for dredging",
  "2-3 eggs, beaten",
  "Panko, enough for coating",
  "Grated Parmesan mixed into the panko",
  "Salt and black pepper",
  "Olive oil for shallow frying",
];

const sauceIngredients = [
  "2 tablespoons olive oil",
  "1 onion, diced",
  "4 garlic cloves, minced",
  "1 tablespoon tomato paste",
  "1 can, 28 ounces, crushed tomatoes",
  "1-2 tablespoons soy sauce",
  "1 teaspoon sugar",
  "Chili flakes, to taste",
  "Salt and black pepper",
];

const allIngredients = [...schnitzelIngredients, ...sauceIngredients];

const sauceSteps = [
  "Heat the oil over medium heat.",
  "Cook the onion until softened.",
  "Add the garlic and cook for 30 seconds.",
  "Add the tomato paste and cook until slightly darkened.",
  "Add the crushed tomatoes, soy sauce, sugar, and chili flakes.",
  "Simmer for about 20 minutes.",
  "Season to taste.",
];

const schnitzelSteps = [
  "Pound the chicken to an even thickness.",
  "Season with salt and pepper.",
  "Coat in flour, then egg, then the panko-Parmesan mixture.",
  "Heat the oil to about 350 F.",
  "Fry for 3-4 minutes per side, until crisp, golden, and cooked through.",
  "Rest on a wire rack.",
  "Serve with the sauce underneath or only lightly spooned over the top so the crust remains crisp.",
];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "American",
  recipeYield: "About 4 portions",
  recipeIngredient: allIngredients,
  recipeInstructions: [...sauceSteps, ...schnitzelSteps].map((step) => ({
    "@type": "HowToStep",
    text: step,
  })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Western
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Schnitzel</h2>
          <p class="text-sm text-gray-500">About 4 portions.</p>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {schnitzelIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Red Sauce</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {sauceIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Red Sauce Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {sauceSteps.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Schnitzel Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {schnitzelSteps.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
