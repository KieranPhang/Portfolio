---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Hong Shao Rou";
const recipeTagline = "Red-braised pork belly, caramelized then reduced until it clings glossy to the meat.";
const recipeDescription =
  "I caramelize sugar in rendered pork fat, braise the belly low and slow in soy and Shaoxing wine, then reduce the liquid until it turns glossy.";

const ingredients = [
  "3 pounds pork belly",
  "3 tablespoons sugar",
  "2 tablespoons oil",
  "3 tablespoons light soy sauce",
  "1 tablespoon dark soy sauce",
  "1 cup Shaoxing wine",
  "2 cups water or stock",
  "3 slices ginger",
  "3 scallions, tied into knots",
  "1-2 star anise, optional",
  "1 small cinnamon stick, optional",
  "1 bay leaf, optional",
  "Dried chili, optional",
  "Rock sugar in place of granulated sugar, optional",
  "Small amount oyster sauce, optional",
  "Small splash black vinegar at the end, optional",
];

const steps = [
  "Cut the pork belly into large bite-size cubes.",
  "Put the pork in a pot of cold water and bring it to a boil.",
  "Blanch for 5 minutes.",
  "Drain, rinse, and dry the pork thoroughly.",
  "Heat the oil in a heavy pot.",
  "Brown the pork belly in batches. Remove it.",
  "Add the sugar to the rendered fat and cook carefully until amber.",
  "Return the pork and coat it in the caramel.",
  "Add the light soy, dark soy, Shaoxing wine, water or stock, ginger, scallions, and any optional whole spices.",
  "Bring to a simmer.",
  "Cover and cook over low heat for 60-90 minutes, stirring occasionally, until the pork is tender.",
  "Uncover and increase the heat slightly.",
  "Reduce the liquid until it becomes glossy and clings to the pork.",
  "Remove the scallions and whole spices.",
  "Add a small splash of black vinegar when using it.",
  "Rest briefly before serving with rice.",
];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "Chinese",
  recipeYield: "Approximately 6-8 servings",
  recipeIngredient: ingredients,
  recipeInstructions: steps.map((step) => ({
    "@type": "HowToStep",
    text: step,
  })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Chinese
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Ingredients</h2>
          <p class="text-sm text-gray-500">Approximately 6-8 servings.</p>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {ingredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {steps.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Reheating</h2>
          <p class="text-gray-300 leading-relaxed">
            Reheat slowly with a splash of water. The dish improves after chilling overnight because the
            flavors settle and excess fat can be removed from the top.
          </p>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
