---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Chicken Cutlet with Mushroom Cream Gravy";
const recipeTagline = "Fried breaded cutlets with a mushroom cream gravy built in the same skillet's fond.";
const recipeDescription =
  "I fry breaded chicken cutlets, then build a mushroom cream gravy in the same skillet and pour it over right before serving.";

const cutletIngredients = [
  "2 pounds chicken thighs or cutlets",
  "Flour",
  "2-3 eggs, beaten",
  "Panko",
  "Olive oil for frying",
  "Salt and black pepper",
];

const gravyIngredients = [
  "12-16 ounces mushrooms, sliced",
  "2 tablespoons butter",
  "3-4 garlic cloves, minced",
  "1 cup chicken stock",
  "1 cup heavy cream",
  "Salt and black pepper",
];

const allIngredients = [...cutletIngredients, ...gravyIngredients];

const steps = [
  "Season, bread, and shallow-fry the chicken using the flour then egg then panko sequence.",
  "Cook for approximately 3-5 minutes per side, then remove to a rack.",
  "Carefully pour off excess oil from the skillet.",
  "Add the butter and mushrooms.",
  "Sauté the mushrooms for 5-7 minutes, until browned.",
  "Add the garlic and cook for 30 seconds.",
  "Deglaze with the chicken stock and simmer for 2-3 minutes.",
  "Add the heavy cream.",
  "Simmer for 5-8 minutes, until the gravy coats a spoon.",
  "Season with salt and pepper.",
  "Pour the gravy over or beside the cutlets immediately before serving.",
];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "American",
  recipeYield: "About 4 portions",
  recipeIngredient: allIngredients,
  recipeInstructions: steps.map((step) => ({
    "@type": "HowToStep",
    text: step,
  })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Western
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Cutlet</h2>
          <p class="text-sm text-gray-500">About 4 portions.</p>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {cutletIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Mushroom Gravy</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {gravyIngredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {steps.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
