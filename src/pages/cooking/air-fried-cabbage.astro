---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Air-Fried Cabbage";
const recipeTagline = "Cabbage cut and cooked to hit either maximum crunch or maximum low-calorie volume.";
const recipeDescription =
  "Cabbage tuned for either max crunch or max low-calorie volume, because those two goals turned out to need opposite settings.";

const steps = [
  "Cut cabbage into thicker ribbons or wedges to preserve structure.",
  "Cook around 340-350 F.",
  "Use enough oil to coat lightly, not saturate.",
  "Add fragile powdered spices after cooking when scorching is a concern.",
  "Toss or rotate so exposed edges do not burn before the thicker portions soften.",
];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "Sides",
  recipeIngredient: ["Cabbage", "Neutral oil", "Powdered spices, to taste"],
  recipeInstructions: steps.map((step) => ({ "@type": "HowToStep", text: step })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Sides
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Useful technique</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {steps.map((step) => <li>{step}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Texture choice</h2>
          <p class="text-gray-300 leading-relaxed">Cabbage can be optimized for:</p>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            <li><span class="font-medium">Crunch:</span> thicker cuts, shorter cooking time, less crowding.</li>
            <li><span class="font-medium">Calorie deficit volume:</span> softer cook, little oil, larger portion.</li>
          </ul>
          <p class="text-gray-300 leading-relaxed">
            Trying to maximize both extreme crispness and minimal oil was identified as a tradeoff rather than
            a single solvable setting.
          </p>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
