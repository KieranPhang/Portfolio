---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Costco-Style Mocha Freeze";
const recipeTagline = "A copycat mocha freeze, corrected on the ice ratio until it actually froze instead of blending into a milkshake.";
const recipeDescription =
  "A copycat mocha freeze fixed by an ice-ratio correction and a frozen coffee-cube method that skips the meltwater dilution.";

const ingredients = [
  "1 cup strong cold coffee",
  "3/4 cup milk",
  "3 tbsp chocolate syrup",
  "2.5-3 cups ice for the corrected freeze texture",
  "1-2 tsp sugar, optional",
  "Pinch of salt",
  "Optional: 1/2 tsp xanthan gum or 1 tsp instant pudding mix",
];

const steps = [
  "Put coffee, milk, chocolate, sugar, and salt in the blender.",
  "Add ice last, on top of the liquids.",
  "Blend 20-30 seconds on high.",
  "Add ice if thin, or a small splash of milk if too thick.",
];

const bestTextureIngredients = ["1 cup coffee cubes", "3/4 cup milk", "3 tbsp chocolate syrup"];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "Western",
  recipeYield: "1 large serving",
  recipeIngredient: ingredients,
  recipeInstructions: steps.map((step) => ({ "@type": "HowToStep", text: step })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Western
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>

          <p class="text-sm sm:text-base text-gray-400">Yield: one large serving.</p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Base recipe</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {ingredients.map((item) => <li>{item}</li>)}
          </ul>
          <p class="text-gray-300 leading-relaxed">
            The initial 1.5-cup ice ratio produced a smooth liquid rather than a freeze. The corrected ratio
            uses substantially more ice.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {steps.map((step) => <li>{step}</li>)}
          </ol>
          <p class="text-gray-300 leading-relaxed">
            Liquid goes at the bottom so the blades can spin and pull the ice downward.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Best texture method</h2>
          <p class="text-gray-300 leading-relaxed">Freeze coffee in ice-cube trays, then blend:</p>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {bestTextureIngredients.map((item) => <li>{item}</li>)}
          </ul>
          <p class="text-gray-300 leading-relaxed">
            This avoids dilution and more closely imitates a frozen commercial base.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Troubleshooting</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            <li>Smooth liquid: add 1-1.5 cups more ice.</li>
            <li>Ice melts immediately: coffee was not cold enough.</li>
            <li>Separates quickly: add xanthan gum or pudding mix.</li>
            <li>Blender stalls: pulse liquids first, then add ice.</li>
          </ul>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
