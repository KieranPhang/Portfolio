---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const recipeName = "Soup-Pot Chicken Stock";
const recipeTagline = "A long bare-simmer stock built from a stripped rotisserie carcass, no pressure cooker needed.";
const recipeDescription =
  "I turn a stripped rotisserie chicken carcass into a clean stock with a five to six hour bare simmer instead of a pressure cooker.";

const ingredients = [
  "Bones and carcass from 1 rotisserie chicken",
  "10-12 cups water",
  "1 onion, quartered, optional",
  "4-6 garlic cloves, smashed, optional",
  "Several slices ginger, optional",
  "1 teaspoon salt, optional; final seasoning is normally done when the stock is used",
];

const steps = [
  "Strip usable meat from the rotisserie carcass and reserve it for another recipe.",
  "Put the bones, skin, cartilage, and optional aromatics into a large soup pot.",
  "Add 10-12 cups water.",
  "Bring just to a boil, then immediately drop to the barest simmer. Skim any foam in the first 20 minutes.",
  "Simmer gently, partially covered, for 5-6 hours. Top up with water if the bones start to poke out.",
  "Strain through a fine-mesh sieve.",
  "Cool quickly, then refrigerate.",
  "Remove the solidified fat from the surface when cold if a leaner stock is wanted.",
];

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Recipe",
  name: recipeName,
  description: recipeDescription,
  recipeCuisine: "American",
  recipeYield: "About 2-3 quarts",
  totalTime: "PT6H",
  recipeIngredient: ingredients,
  recipeInstructions: steps.map((step) => ({
    "@type": "HowToStep",
    text: step,
  })),
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{recipeName} | {siteConfig.name}</title>
    <meta name="description" content={recipeDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <main class="pt-24 pb-16">
      <section class="max-w-4xl mx-auto px-6 space-y-10">
        <header class="space-y-3">
          <p class="text-sm uppercase tracking-[0.25em]" style={`color:${siteConfig.accentColor}`}>
            Kitchen / Basics
          </p>

          <h1 class="text-4xl sm:text-5xl font-bold text-gray-100">{recipeName}</h1>

          <p class="text-base sm:text-lg text-gray-400">{recipeTagline}</p>

          <p class="text-sm sm:text-base italic text-gray-500">
            Converted from the original pressure-cooker method, since I don't own a pressure cooker; my
            standing practice is a long simmer instead.
          </p>
        </header>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Ingredients</h2>
          <p class="text-sm text-gray-500">Yields about 2-3 quarts. Active time is 10-15 minutes; total time is about 6 hours.</p>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            {ingredients.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Method</h2>
          <ol class="list-decimal list-inside space-y-2 text-gray-300">
            {steps.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-gray-100">Storage</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-300">
            <li>Refrigerator: 4-5 days</li>
            <li>Freezer: 2-3 months</li>
          </ul>
        </section>

        <div class="pt-4">
          <a
            href="/cooking"
            class="text-sm underline-offset-2 hover:underline"
            style={`color:${siteConfig.accentColor}`}
          >
            ← Back to all recipes
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
