---
import { siteConfig } from "../config";
---

  <div
    id="hero"
    class="relative isolate overflow-hidden bg-background py-24 md:h-screen"
    style={`--accent-color: ${siteConfig.accentColor}`}
  >
    <!-- Hero illustration — brightness: edit the brightness() value below -->
    <img
  src="/images/WebsiteEyecatch.svg"
  alt=""
  aria-hidden="true"
  class="absolute inset-y-0 right-0 -z-10 h-full w-auto max-w-none pointer-events-none arm-image"
  style="
    mix-blend-mode: screen;
    filter: sepia(1) hue-rotate(190deg) saturate(2.5) brightness(3.5);
    opacity: 0.9;
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%);
  "
/>


    <!-- Dark gradient overlay -->
    <div
      class="absolute inset-0 -z-10"
      style={`background:
        radial-gradient(ellipse 900px 1200px at 0% 0%,
          ${siteConfig.accentColor}35 0%,
          ${siteConfig.accentColor}18 18%,
          rgba(13, 15, 18, 0.1) 55%,
          rgba(13, 15, 18, 0.1) 100%
        )`}
    ></div>


  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
    <div>
      <h2 class="text-pretty text-base sm:text-xl md:text-4xl font-bold tracking-tight text-gray-200 animate-fade-in">
        Hey!
      </h2>
      <h1 class="mt-6 sm:mt-8 md:mt-10 text-pretty text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-bold tracking-tight text-gray-100 animate-fade-in animation-delay-200">
        I'm <span style={{ color: siteConfig.accentColor }}>{siteConfig.name}</span>
      </h1>
      <p class="mt-4 sm:mt-6 md:mt-8 text-pretty text-sm sm:text-base md:text-lg/8 font-medium text-gray-300 animate-fade-in animation-delay-400">
        {siteConfig.title}
      </p>
    </div>
  </div>

  <!-- Robot init terminal — md+ only, bottom-right above social icons -->
  <div class="hidden md:block absolute font-mono text-xs leading-relaxed" style="bottom: 10rem; right: 6rem;">
    <div class="terminal-line line1"><span class="term-tag">[SYS]</span><span class="text-gray-300">  Joint initialization sequence...</span></div>
    <div class="terminal-line line2"><span class="term-tag">[J1]</span><span class="text-gray-300">   Base rotation      ± 170°  </span><span class="text-gray-500">·  OK</span></div>
    <div class="terminal-line line3"><span class="term-tag">[J2]</span><span class="text-gray-300">   Shoulder joint     ± 135°  </span><span class="text-gray-500">·  OK</span></div>
    <div class="terminal-line line4"><span class="term-tag">[J3]</span><span class="text-gray-300">   Elbow joint        ± 150°  </span><span class="text-gray-500">·  OK</span></div>
    <div class="terminal-line line5"><span class="term-tag">[J6]</span><span class="text-gray-300">   Tool flange        ± 360°  </span><span class="text-gray-500">·  OK</span></div>
    <div class="terminal-line line6"><span class="term-tag">[SYS]</span><span class="text-gray-300">  STATUS: OPERATIONAL </span><span class="term-tag">✓</span></div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 p-8 sm:p-12 md:p-24 flex gap-x-4 sm:gap-x-6 md:gap-x-8 text-gray-300 animate-fade-in animation-delay-600">
    {siteConfig.social?.email && (
      <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="transition-colors duration-300 hover:text-[var(--accent-color)]">
        <!-- icon unchanged -->
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
          <path d="M3 7l9 6l9 -6" />
        </svg>
      </a>
    )}

    {siteConfig.social?.linkedin && (
      <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="transition-colors duration-300 hover:text-[var(--accent-color)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8">
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M8 11v5" />
          <path d="M8 8v.01" />
          <path d="M12 16v-5" />
          <path d="M16 16v-3a2 2 0 1 0 -4 0" />
          <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
        </svg>
      </a>
    )}

    {siteConfig.social?.github && (
      <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="transition-colors duration-300 hover:text-[var(--accent-color)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
          <path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2c2.2-.2 4.5-1.1 4.5-5a3.9 3.9 0 0 0-1-2.7a3.6 3.6 0 0 0-.1-2.7s-.8-.3-2.7 1a9.4 9.4 0 0 0-5 0c-1.9-1.3-2.7-1-2.7-1a3.6 3.6 0 0 0-.1 2.7a3.9 3.9 0 0 0-1 2.7c0 3.9 2.3 4.8 4.5 5c-.6.6-.6 1.2-.5 2v3.5"/>
        </svg>
      </a>
    )}
  </div>
</div>

<style>
/* ── Animation B: Arm clip-path wipe reveal (top → bottom) ── */
@keyframes arm-wipe {
  from { clip-path: inset(0 0 100% 0); }
  to   { clip-path: inset(0 0 0% 0); }
}

.arm-image {
  clip-path: inset(0 0 100% 0);
  animation: arm-wipe 3.5s cubic-bezier(0.4, 0, 0.2, 1) 0.3s forwards;
}

/* ── Animation C: Typewriter terminal panel ── */

/* 39-char lines: 39 × 40ms = 1560ms */
@keyframes type-39 {
  from { width: 0ch; }
  to   { width: 39ch; }
}

/* 28-char line 6: 28 × 40ms = 1120ms */
@keyframes type-28 {
  from { width: 0ch; }
  to   { width: 28ch; }
}

/* Cursor blinks ~1.5 cycles then hides; fill-mode: forwards holds opacity 0 */
@keyframes cursor-blink {
  0%   { opacity: 1; }
  30%  { opacity: 1; }
  31%  { opacity: 0; }
  60%  { opacity: 0; }
  61%  { opacity: 1; }
  99%  { opacity: 1; }
  100% { opacity: 0; }
}

.term-tag {
  color: var(--accent-color);
}

.terminal-line {
  overflow: hidden;
  white-space: nowrap;
  width: 0ch;
}

/* Cursor sits after the last revealed character; hidden until its line starts */
.terminal-line::after {
  content: "|";
  color: var(--accent-color);
  opacity: 0;
}

/* line1: delay  3.60s · 39 ch · 1.56s · ends  5.16s */
.line1        { animation: type-39       1.56s steps(39, end)  3.60s forwards; }
.line1::after { animation: cursor-blink 1.56s                  3.60s forwards; }

/* line2: delay  5.16s · 39 ch · 1.56s · ends  6.72s */
.line2        { animation: type-39       1.56s steps(39, end)  5.16s forwards; }
.line2::after { animation: cursor-blink 1.56s                  5.16s forwards; }

/* line3: delay  6.72s · 39 ch · 1.56s · ends  8.28s */
.line3        { animation: type-39       1.56s steps(39, end)  6.72s forwards; }
.line3::after { animation: cursor-blink 1.56s                  6.72s forwards; }

/* line4: delay  8.28s · 39 ch · 1.56s · ends  9.84s */
.line4        { animation: type-39       1.56s steps(39, end)  8.28s forwards; }
.line4::after { animation: cursor-blink 1.56s                  8.28s forwards; }

/* line5: delay  9.84s · 39 ch · 1.56s · ends 11.40s */
.line5        { animation: type-39       1.56s steps(39, end)  9.84s forwards; }
.line5::after { animation: cursor-blink 1.56s                  9.84s forwards; }

/* line6: delay 11.40s · 28 ch · 1.12s · ends 12.52s */
.line6        { animation: type-28       1.12s steps(28, end) 11.40s forwards; }
.line6::after { animation: cursor-blink 1.12s                 11.40s forwards; }
</style>
